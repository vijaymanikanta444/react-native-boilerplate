{
  "name": "create-viet-native-app",
  "version": "0.0.5",
  "description": "CLI to configure and bootstrap a React Native app template for VIET projects",
  "organization": {
    "name": "VISAKHA INSTITUTE OF ENGINEERING & TECHNOLOGY",
    "supportEmail": "support@viet.edu.in",
    "ownerEmail": "owner@viet.edu.in"
  },
  "releaseDate": null,
  "private": false,
  "keywords": [
    "react-native",
    "cli",
    "scaffold",
    "template",
    "viet"
  ],
  "bin": {
    "create-viet-native-app": "scripts/configure.js"
  },
  "scripts": {
    "android": "react-native run-android",
    "android:apk:release": "cd android && ./gradlew assembleRelease",
    "android:aab:release": "cd android && ./gradlew bundleRelease",
    "clean:android": "cd android && ./gradlew clean",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "pods": "cd ios && bundle exec pod install",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "release:bump": "node scripts/bump-version.js",
    "prepare": "husky install",
    "configure": "node scripts/configure.js --in-place",
    "configure:interactive": "node scripts/configure.js --interactive --in-place"
  },
  "dependencies": {
    "@react-native/new-app-screen": "^0.84.1",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "husky": "^9.0.11",
    "jest": "^29.6.3",
    "lint-staged": "^15.2.11",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": "prettier --write",
    "*.json": "prettier --write"
  }
}
